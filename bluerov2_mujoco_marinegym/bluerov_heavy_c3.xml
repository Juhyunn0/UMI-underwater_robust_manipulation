<!--
  BlueROV2 HEAVY rigid body imported from MarineGym's BlueROVHeavy asset.

  Provenance
  ----------
  Mass, inertia and the 8 thruster mount transforms are extracted verbatim from
  MarineGym's Isaac asset (values verified directly from the USD):
      external/MarineGym/.../usd/BlueROVHeavy/BlueROVHeavy.usd
  Hydrodynamic coefficients + the T200 rotor config live in
  ./marinegym_assets/BlueROVHeavy.yaml.

  Difference vs the standard BlueROV2 (bluerov.xml)
  -------------------------------------------------
    * mass 11.2 -> 11.5 kg;  inertia [0.30375 0.626 0.5769] -> [0.3291 0.6347 0.6109]
      DERIVED from the BlueROV2 tensor by parallel-axis of the vertical-thruster layout
      change (compute_heavy_inertia.py); the farol Heavy USD's own [0.21 0.245 0.245] is
      a non-physical Gazebo-stability hand-tune -- see docs/CONTROL_METHODOLOGY.md
    * buoyant volume 0.0113459 -> 0.0116499 m^3 (in BlueROVHeavy.yaml)
    * 6 thrusters -> 8: the same 4 horizontal (thruster_0..3) PLUS 4 vertical
      (thruster_4..7) at the four corners (+-0.12, +-0.22, -0.005), all +Z.
      -> the allocation is now rank 6 (FULLY ACTUATED): roll AND pitch are
         directly controllable (the standard BlueROV2 is rank-5, no pitch).
    * SAME T200 thrusters (ctrlrange -51.55..64.13 N), SAME added mass / drag.

  The visual meshes in ./meshes/ are reused from the standard BlueROV2 (the body
  hull + the T200 thruster); they are visual/collision only and do not affect the
  dynamics, which are governed entirely by the <inertial> + thruster sites below.

  Frame: x forward, y left, z up (FLU). World Z-up, gravity (0 0 -9.81) ON.
  Each thruster_i site's local +X is the thrust direction; one <general> force
  actuator ("thr0".."thr7") drives it (ctrl = thrust in NEWTONS via the T200 curve
  in thrusters.py). Hydrodynamics are injected at runtime by hydro.py.
-->
<mujoco model="bluerov2_heavy_c3">
<!-- GENERATED by gen_c3_variant.py from bluerov_heavy.xml - DO NOT EDIT BY HAND (rerun the script).
     BlueROV2 Heavy + MarineSitu C3 stereo camera on its C3-BR bracket = exactly the lab's Onshape assembly
     (NO Newton gripper - not in Onshape yet). BODY FRAME RE-ORIGINED at the composite COM (shift 0.02559 0.00103 -0.02007
     from the heavy frame) so origin==COM, which the dobmpc predictor / params.ZG_MASS=0 / hydro all assume.
     C3 baked into <inertial> (bracket is visual-only, mass unknown). Hydro coeffs stay the heavy set except
     volume/coBM (marinegym_assets/BlueROVHeavyC3.yaml). Net buoyancy ~-3.1 N (C3 payload, no trim foam - SINKS).
     C3 pose measured from Onshape 2026-07-19 (process_c3_mesh.py). See compute_payload_inertia.py. -->

  <compiler angle="radian" meshdir="meshes" autolimits="true"/>

  <!-- density=0 viscosity=0: MuJoCo's built-in fluid model is OFF on purpose;
       all hydrodynamics are injected by hydro.py. -->
  <option timestep="0.002" integrator="implicitfast" density="0" viscosity="0"/>

  <visual>
    <headlight ambient="0.6 0.6 0.62" diffuse="0.85 0.85 0.88" specular="0.25 0.25 0.25"/>
    <rgba haze="0.12 0.18 0.28 1"/>
    <scale framelength="0.25" framewidth="0.008"/>
    <global offwidth="1280" offheight="960"/>
  </visual>

  <asset>
    <mesh name="bluerov_body"     file="bluerov_body.obj"/>
    <mesh name="bluerov_thruster" file="bluerov_thruster.obj"/>
    <material name="hull"      rgba="0.33 0.37 0.44 1" specular="0.35" shininess="0.3"/>
    <material name="thruster"  rgba="0.12 0.13 0.16 1" specular="0.4" shininess="0.4"/>
    <material name="collision" rgba="0.85 0.45 0.20 0.25"/>
    <material name="c3_housing" rgba="0.231373 0.380392 0.705882 1" specular="0.35" shininess="0.4"/>
    <material name="c3_mount_gray" rgba="0.752941 0.752941 0.752941 1" specular="0.4" shininess="0.4"/>
    <mesh name="c3_camera" file="c3_camera.stl" inertia="shell"/>
    <mesh name="c3_mount" file="c3_mount.stl" inertia="shell"/>
    <!-- Colored BlueROV2 Heavy skin (VISUAL ONLY): body split by GeomSubset out of the
         MarineGym BlueROVHeavy USD into cyan foam / white tube / black frame / silver
         hardware (extract_meshes.py --colored). Frame + thruster shrouds are in this mesh
         set, so the plain gray body+thruster geoms are replaced by these. Dynamics use the
         explicit <inertial>, the collision box, and the thruster sites/actuators below —
         all UNCHANGED — so this is purely cosmetic (verified Delta=0). -->
    <mesh name="rovc_cyan"   file="rov_body_cyan.obj"/>
    <mesh name="rovc_white"  file="rov_body_white.obj"/>
    <mesh name="rovc_black"  file="rov_body_black.obj"/>
    <mesh name="rovc_silver" file="rov_body_silver.obj"/>
    <material name="rovc_cyan"   rgba="0.16 0.55 0.78 1" specular="0.3" shininess="0.35"/>
    <material name="rovc_white"  rgba="0.90 0.90 0.88 1" specular="0.3" shininess="0.35"/>
    <material name="rovc_black"  rgba="0.10 0.10 0.11 1" specular="0.3" shininess="0.35"/>
    <material name="rovc_silver" rgba="0.60 0.62 0.65 1" specular="0.4" shininess="0.4"/>
  </asset>

  <default>
    <default class="visual">
      <geom type="mesh" contype="0" conaffinity="0" group="2"/>
    </default>
    <default class="collision">
      <geom type="box" group="3" material="collision" contype="1" conaffinity="1"/>
    </default>
    <default class="thruster">
      <site type="cylinder" size="0.012 0.004" rgba="0.1 0.7 1 1" group="4"/>
    </default>
    <default class="ref">
      <site type="sphere" size="0.012" group="4"/>
    </default>
  </default>

  <worldbody>
    <light name="key"  pos="0.8 0.8 2.5"  dir="-0.3 -0.3 -1" directional="true"
           diffuse="0.55 0.55 0.6" specular="0.2 0.2 0.2"/>
    <light name="fill" pos="-0.8 -0.6 1.2" dir="0.4 0.3 -1" directional="true"
           diffuse="0.35 0.35 0.4" specular="0.1 0.1 0.1"/>
    <body name="base_link" pos="0 0 0">
      <freejoint name="free"/>
      <!-- mass 11.5 from the MarineGym BlueROVHeavy USD; inertia DERIVED from the
           BlueROV2 tensor + parallel-axis of the vertical-thruster layout change
           (compute_heavy_inertia.py). The USD/farol [0.21 0.245 0.245] is a non-physical
           Gazebo-stability hand-tune -- see docs/CONTROL_METHODOLOGY.md / rov_model.py. -->
      <inertial pos="0 0 0" mass="13.2000" diaginertia="0.37014 0.73153 0.67460"/>
      <!-- ^ composite: heavy 11.5 + C3 1.700 kg; frame origin = composite COM. DIAGONAL inertia so body_iquat
           stays identity (fullinertia would axis-permute the inertial frame and break hydro drag). -->

      <!-- ===== body visual: colored BlueROV2 Heavy skin (frame + thruster shrouds/props
           are all in this mesh set) — replaces the single gray body + 8 gray thruster geoms.
           VISUAL ONLY (contype=0 conaffinity=0 via class="visual"); dynamics unchanged. ===== -->
      <geom class="visual" mesh="rovc_cyan"   material="rovc_cyan" pos="-0.02559 -0.00103 0.02007"/>
      <geom class="visual" mesh="rovc_white"  material="rovc_white" pos="-0.02559 -0.00103 0.02007"/>
      <geom class="visual" mesh="rovc_black"  material="rovc_black" pos="-0.02559 -0.00103 0.02007"/>
      <geom class="visual" mesh="rovc_silver" material="rovc_silver" pos="-0.02559 -0.00103 0.02007"/>

      <!-- ===== collision proxy ===== -->
      <geom class="collision" pos="-0.02559 -0.00103 -0.02993" size="0.25 0.175 0.125"/>

      <!-- ===== 8 thruster force sites (0..3 horizontal, 4..7 vertical). The shroud/prop
           VISUALS live in the colored body mesh above, so only the force sites remain — pos/
           quat are byte-identical to before, so allocation/thrust directions are unchanged. -->
      <site name="thruster_0" class="thruster" pos="0.10991 -0.10103 -0.05243" quat="0.92388 0 0 0.382684"/>
      <site name="thruster_1" class="thruster" pos="0.10991 0.09897 -0.05243" quat="0.92388 0 0 -0.382684"/>
      <site name="thruster_2" class="thruster" pos="-0.17309 -0.10103 -0.05243" quat="0.382683 0 0 0.92388"/>
      <site name="thruster_3" class="thruster" pos="-0.17309 0.09897 -0.05243" quat="-0.382683 0 0 0.92388"/>
      <site name="thruster_4" class="thruster" pos="0.09441 -0.22103 0.01507" quat="-0.707107 0 0.707107 0"/>
      <site name="thruster_5" class="thruster" pos="0.09441 0.21897 0.01507" quat="-0.707107 0 0.707107 0"/>
      <site name="thruster_6" class="thruster" pos="-0.14559 -0.22103 0.01507" quat="-0.707107 0 0.707107 0"/>
      <site name="thruster_7" class="thruster" pos="-0.14559 0.21897 0.01507" quat="-0.707107 0 0.707107 0"/>
      <!-- ===== PAYLOAD: MarineSitu C3 stereo camera + C3-BR bracket (real CAD meshes,
           FRONT-BOTTOM, lens FORWARD level — measured from the Onshape assembly
           2026-07-19, meshes/c3_payload_frames.json). The STLs are pre-baked into the
           mount orientation, so the geoms need NO quat: MuJoCo composes its internal
           principal-axis reframe back into the compiled geom pose, i.e. geom pos/quat
           apply to the mesh AS AUTHORED (same reason the quat-less rovc_* skins render
           correctly). The 3 <camera>s sit at the LENS PLANE (xyaxes). ===== -->
      <geom class="visual" type="mesh" mesh="c3_mount" pos="0.10991 0.00444 -0.14600"
            material="c3_mount_gray"/>
      <geom class="visual" type="mesh" mesh="c3_camera" pos="0.17310 0.00697 -0.13576"
            material="c3_housing"/>
      <camera name="c3_center" pos="0.21390 0.00444 -0.13530"
              xyaxes="-0.00000 -1.00000 -0.00000 -0.00560 0.00000 0.99998" fovy="52.5"/>
      <camera name="c3_left" pos="0.21390 0.04194 -0.13530"
              xyaxes="-0.00000 -1.00000 -0.00000 -0.00560 0.00000 0.99998" fovy="55.5"/>
      <camera name="c3_right" pos="0.21390 -0.03306 -0.13530"
              xyaxes="-0.00000 -1.00000 -0.00000 -0.00560 0.00000 0.99998" fovy="55.5"/>


      <!-- reference site at the base_link origin -->
      <site name="base_origin" class="ref" pos="-0.02559 -0.00103 0.02007" rgba="1 0.2 0.2 1"/>
    </body>
  </worldbody>

  <!-- ===== 8 thruster force actuators (ctrl = thrust in N, T200 curve) ===== -->
  <actuator>
    <general name="thr0" site="thruster_0" gear="1 0 0 0 0 0" ctrlrange="-51.5507 64.1319"/>
    <general name="thr1" site="thruster_1" gear="1 0 0 0 0 0" ctrlrange="-51.5507 64.1319"/>
    <general name="thr2" site="thruster_2" gear="1 0 0 0 0 0" ctrlrange="-51.5507 64.1319"/>
    <general name="thr3" site="thruster_3" gear="1 0 0 0 0 0" ctrlrange="-51.5507 64.1319"/>
    <general name="thr4" site="thruster_4" gear="1 0 0 0 0 0" ctrlrange="-51.5507 64.1319"/>
    <general name="thr5" site="thruster_5" gear="1 0 0 0 0 0" ctrlrange="-51.5507 64.1319"/>
    <general name="thr6" site="thruster_6" gear="1 0 0 0 0 0" ctrlrange="-51.5507 64.1319"/>
    <general name="thr7" site="thruster_7" gear="1 0 0 0 0 0" ctrlrange="-51.5507 64.1319"/>
  </actuator>
</mujoco>
