<!--
  Phase 1 deliverable: the BlueROV2 MJCF.   /   Phase 1 산출물: BlueROV2 MJCF.

  EN: World = NED (x north, y east, z DOWN) so gravity = +9.81 z; MuJoCo
      applies the weight W = m g at the CG.  Body = FRD with origin at the
      centre of buoyancy (CB); the CG sits z_G = 0.02 m below it (inertial
      pos 0 0 0.02), which produces the m*z_G mass coupling and the
      hydrostatic restoring couple.
  KR: 월드 = NED(x 북, y 동, z 아래)라 중력 = +9.81 z; MuJoCo가 CG에서
      무게 W=m g 를 적용. body = FRD, 원점은 부력중심(CB), CG는 그보다
      z_G=0.02 m 아래(inertial pos 0 0 0.02) -> m*z_G 질량 결합과 정수압
      복원 짝힘이 자연히 생긴다.

  EN: Buoyancy and all hydrodynamics are NOT in this file - they are injected
      by rov_sim/env.py via xfrc_applied.  MuJoCo's own fluid model is off
      (density = viscosity = 0).  Every <geom> is cosmetic (contype =
      conaffinity = 0) and inertia comes from the explicit <inertial>, so
      geometry never affects the dynamics.
  KR: 부력과 모든 유체력은 이 파일에 없음 - rov_sim/env.py 가 xfrc_applied
      로 주입. MuJoCo 자체 유체모델은 끔(density=viscosity=0). 모든 <geom>은
      장식용(충돌 없음)이고 관성은 명시적 <inertial>에서 오므로, 형상은
      동역학에 전혀 영향 없음.

  EN: The 6 thruster cylinders are drawn at the true BlueROV2 layout (4
      vectored at 45 deg + 2 vertical); the thrust they represent is applied
      analytically in Phase 2 through the K matrix, not by MJCF actuators.
  KR: 추진기 실린더 6개는 실제 BlueROV2 배치(45도 벡터드 4 + 수직 2)로 그렸고,
      이들이 내는 추력은 Phase 2에서 K 행렬로 해석적으로 적용(=MJCF 액추에이터가
      아니라 xfrc_applied 주입).
-->
<mujoco model="bluerov2_scratch_ned">
  <option timestep="0.002" gravity="0 0 9.81" integrator="implicitfast"
          density="0" viscosity="0"/>

  <visual>
    <headlight ambient="0.5 0.5 0.55" diffuse="0.7 0.7 0.75" specular="0.3 0.3 0.3"/>
    <scale framelength="0.3" framewidth="0.01"/>
  </visual>

  <asset>
    <material name="float"  rgba="0.20 0.22 0.27 1" specular="0.4" shininess="0.3"/>
    <material name="accent" rgba="0.10 0.52 0.95 1" emission="0.25"/>
    <material name="tube"   rgba="0.60 0.78 0.95 0.32" specular="0.7" shininess="0.6" reflectance="0.2"/>
    <material name="batt"   rgba="0.07 0.07 0.08 1" specular="0.3" shininess="0.2"/>
    <material name="frame"  rgba="0.12 0.12 0.14 1" specular="0.3" shininess="0.25"/>
    <material name="duct"   rgba="0.13 0.13 0.15 1" specular="0.4" shininess="0.3"/>
    <material name="prop"   rgba="0.78 0.80 0.84 1" specular="0.6" shininess="0.5"/>
  </asset>

  <default>
    <geom contype="0" conaffinity="0" group="1"/>
  </default>

  <worldbody>
    <light name="key" pos="0.6 0.6 -22" dir="-0.3 -0.3 1" directional="true"
           diffuse="0.55 0.55 0.6" specular="0.25 0.25 0.25"/>
    <body name="base_link" pos="0 0 -20">
      <freejoint name="free"/>
      <inertial pos="0 0 0.02" mass="11.26" diaginertia="0.3 0.63 0.58"/>

      <!-- top buoyancy floats (-z = up) -->
      <geom type="box" material="float" pos="0  0.12 -0.075" size="0.205 0.05 0.032"/>
      <geom type="box" material="float" pos="0 -0.12 -0.075" size="0.205 0.05 0.032"/>
      <geom type="box" material="accent" pos="0  0.12 -0.109" size="0.185 0.045 0.005"/>
      <geom type="box" material="accent" pos="0 -0.12 -0.109" size="0.185 0.045 0.005"/>

      <!-- central electronics enclosure (clear acrylic tube + dome) -->
      <geom type="cylinder" material="tube" zaxis="1 0 0" pos="0 0 -0.01" size="0.05 0.17"/>
      <geom type="sphere"   material="tube" pos="0.18 0 -0.01" size="0.05"/>
      <geom type="cylinder" material="frame" zaxis="1 0 0" pos="-0.175 0 -0.01" size="0.052 0.012"/>

      <!-- bottom battery enclosure -->
      <geom type="cylinder" material="batt" zaxis="1 0 0" pos="0 0 0.055" size="0.038 0.14"/>

      <!-- side frame panels -->
      <geom type="box" material="frame" pos="0  0.168 -0.01" size="0.21 0.004 0.08"/>
      <geom type="box" material="frame" pos="0 -0.168 -0.01" size="0.21 0.004 0.08"/>

      <!-- 4 vectored horizontal thrusters (45 deg, X pattern) -->
      <geom type="cylinder" material="duct" zaxis="1 1 0"  pos="0.156  0.111 0.072" size="0.04 0.03"/>
      <geom type="cylinder" material="prop" zaxis="1 1 0"  pos="0.156  0.111 0.072" size="0.033 0.007"/>
      <geom type="cylinder" material="duct" zaxis="1 -1 0" pos="0.156 -0.111 0.072" size="0.04 0.03"/>
      <geom type="cylinder" material="prop" zaxis="1 -1 0" pos="0.156 -0.111 0.072" size="0.033 0.007"/>
      <geom type="cylinder" material="duct" zaxis="1 -1 0" pos="-0.156  0.111 0.072" size="0.04 0.03"/>
      <geom type="cylinder" material="prop" zaxis="1 -1 0" pos="-0.156  0.111 0.072" size="0.033 0.007"/>
      <geom type="cylinder" material="duct" zaxis="1 1 0"  pos="-0.156 -0.111 0.072" size="0.04 0.03"/>
      <geom type="cylinder" material="prop" zaxis="1 1 0"  pos="-0.156 -0.111 0.072" size="0.033 0.007"/>

      <!-- 2 vertical thrusters (heave) -->
      <geom type="cylinder" material="duct" zaxis="0 0 1" pos="0  0.1105 -0.005" size="0.04 0.026"/>
      <geom type="cylinder" material="prop" zaxis="0 0 1" pos="0  0.1105 -0.005" size="0.033 0.007"/>
      <geom type="cylinder" material="duct" zaxis="0 0 1" pos="0 -0.1105 -0.005" size="0.04 0.026"/>
      <geom type="cylinder" material="prop" zaxis="0 0 1" pos="0 -0.1105 -0.005" size="0.033 0.007"/>

      <site name="origin_cb" pos="0 0 0"    size="0.012" rgba="1 0 0 1"/>
      <site name="cg"        pos="0 0 0.02" size="0.012" rgba="0 1 0 1"/>
    </body>
  </worldbody>
</mujoco>
