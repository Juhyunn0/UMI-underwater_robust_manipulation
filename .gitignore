# Python caches
__pycache__/
*.pyc
*.pyo
*.pyd

# Virtual environments
.venv/
venv/
env/

# Vendor / large binaries (ZED SDK installers, wheels, etc.)
vendor/
*.run
*.whl

# Onshape API credentials (never commit)
.env

# onshape-to-robot export meshes (258 MB of per-part STLs; robot.xml + config.json ARE
# tracked — the poses used by the sim are frozen in process_c3_mesh.py)
assets/CAD files/onshape_export/assets/

# acados generated C code (regenerated on solver construction; not a source artifact)
**/dobmpc/_acados_gen/
MUJOCO_LOG.TXT
*.tar.gz
*.zip

# Local build cache
build_cache/

# Large dataset directory (recordings, calibration data, etc.)
data/

# OS
.DS_Store
Thumbs.db

# Editor / IDE
.vscode/
.idea/
*.swp

# Make sure requirements.txt is tracked even if a parent rule would match
!requirements.txt
